import java.util.ArrayList;
import java.util.Scanner;
import java.io.File;
import java.io.FileWriter;
import java.io.PrintWriter;
import java.io.IOException;
import java.io.FileNotFoundException;

public class Main {
	
	//Login method, Checks username and password, Returns logged-in user object
	public static User login(ArrayList<User> users, Scanner input) {

	    System.out.println("===== Login =====");

	    System.out.print("Enter Username: ");
	    String username = input.next();

	    System.out.print("Enter Password: ");
	    String password = input.next();

	 // checking all users in Users arraylist
	    for(User u : users) {

	        if(u.getUsername().equals(username) && u.getPassword().equals(password)) {

	            System.out.println("Login Successful");
	            System.out.println("Welcome " + u.getName());

	            return u;

	        }

	    }

	    System.out.println("Invalid Username or Password");

	    return null;

	}
	
	//Adds a new sales executive, Admin only feature
	public static void addSalesExecutive(ArrayList<User> users, Scanner input) {

	    input.nextLine();

	    System.out.print("Enter Executive Name: ");
	    String name = input.nextLine();

	    System.out.print("Enter Username: ");
	    String username = input.nextLine();

	    System.out.print("Enter Password: ");
	    String password = input.nextLine();

	 // creating executive objec
	    SalesExecutive executive = new SalesExecutive(name, username, password);

	    users.add(executive);
	 // saving users to file
	    saveUsers(users);

	    System.out.println("Sales Executive Added Successfully");

	}
	
	//Admin menu Allows admin functions
	public static void adminMenu(ArrayList<User> users, Scanner input) {

	    int adminChoice;

	    do {

	        System.out.println("\n===== ADMIN MENU =====");

	        System.out.println("1. Add Sales Executive");
	        System.out.println("2. View Users");
	        System.out.println("3. Logout");

	        System.out.print("Enter Option: ");
	        adminChoice = input.nextInt();

	        switch(adminChoice) {

	            case 1:
	                addSalesExecutive(users, input);
	                break;

	            case 2:
	            	// display all users in user arraylist
	                for(User u : users) {
	                    System.out.println("Name: " + u.getName()+ " | Username: " + u.getUsername());
	                }
	                break;

	            case 3:
	                System.out.println("Logging Out...");
	                break;

	            default:
	                System.out.println("Invalid Option");

	        }

	    }while(adminChoice != 3);

	}
	
	
	//Saves users into users.txt file
	public static void saveUsers(ArrayList<User> users) {

	    try {
	        PrintWriter pw = new PrintWriter(
	                new FileWriter("users.txt")
	        );

	        
	        // writing all users into file
	        for(User u : users) {
	            pw.println(
	                    u.getName() + "," +
	                    u.getUsername() + "," +
	                    u.getPassword() + "," +
	                    u.getClass().getSimpleName());
	        }
	        pw.close();
	        System.out.println("Users Saved Successfully");
	    }

	    catch(IOException e) {
	        System.out.println("Error Saving Users");
	    }
	}
	
	
	//Loads users from file
	public static void loadUsers(ArrayList<User> users) {

	    try {

	        File file = new File("users.txt");
	        Scanner fileReader = new Scanner(file);

	        // reading all lines
	        while(fileReader.hasNextLine()) {
	            String line = fileReader.nextLine();
	            String[] data = line.split(",");

	            // extracting values
	            String name = data[0];
	            String username = data[1];
	            String password = data[2];
	            String role = data[3];

	            // creating objects
	            if(role.equals("Admin")) {
	                users.add(new Admin(name, username, password));
	            }
	            else if(role.equals("SalesExecutive")) {

	                users.add(
	                        new SalesExecutive(
	                                name,
	                                username,
	                                password
	                        )
	                );

	            }

	        }

	        fileReader.close();
	        System.out.println("Users Loaded Successfully");

	    }

	    catch(FileNotFoundException e) {

	        System.out.println("No User File Found");

	    }

	}
	
	
	// Displays sales report, Shows total sales by each executive
	public static void salesReport(ArrayList<Tour> bookings) {

	    ArrayList<String> checkedNames = new ArrayList<>();

	    System.out.println("\n===== SALES REPORT =====");

	    for(Tour t : bookings) {

	        String name = t.getSalesExecutiveName();

	        // avoid duplicate names
	        if(!checkedNames.contains(name)) {

	            double totalSales = 0;

	            for(Tour tour : bookings) {

	                if(tour.getSalesExecutiveName().equals(name)) {

	                    totalSales += tour.calculatePrice();

	                }

	            }
	            System.out.println(name + " : $" + totalSales);
	            checkedNames.add(name);

	        }

	    }

	}
	
	
	//Adds city tour booking
	public static void addCityTour(
	        ArrayList<Tour> bookings,
	        Scanner input,
	        User currentUser
	) {
		// city tour menu

	    System.out.println("===== City Tours =====");

	    System.out.println("1. Melbourne City");
	    System.out.println("2. Melbourne City + Yarra River Boat Cruise");
	    System.out.println("3. Yarra River Cruise + Melbourne Zoo");
	    System.out.println("4. Melbourne City + Melbourne Zoo");
	    System.out.println("5. Melbourne City + Melbourne Aquarium");

	    System.out.print("Choose Tour: ");

	    int choice = input.nextInt();

	    // variables for selected tour
	    String tourName = "";
	    double adultPrice = 0;
	    double childPrice = 0;
	    int duration = 0;

	    // selecting tour
	    switch(choice) {

	        case 1:
	            tourName = "Melbourne City";
	            adultPrice = 35;
	            childPrice = 25;
	            duration = 4;
	            break;

	        case 2:
	            tourName = "Melbourne City + Yarra River Boat Cruise";
	            adultPrice = 65;
	            childPrice = 40;
	            duration = 6;
	            break;

	        case 3:
	            tourName = "Yarra River Cruise + Melbourne Zoo";
	            adultPrice = 75;
	            childPrice = 45;
	            duration = 6;
	            break;

	        case 4:
	            tourName = "Melbourne City + Melbourne Zoo";
	            adultPrice = 65;
	            childPrice = 40;
	            duration = 7;
	            break;

	        case 5:
	            tourName = "Melbourne City + Melbourne Aquarium";
	            adultPrice = 75;
	            childPrice = 45;
	            duration = 6;
	            break;

	        default:
	            System.out.println("Invalid Tour");
	            return;

	    }

	    System.out.print("Enter Adult Count: ");
	    int adultCount = input.nextInt();

	    System.out.print("Enter Child Count: ");
	    int childCount = input.nextInt();

	    // tour capacity validation
	    if(adultCount + childCount > 40) {

	        System.out.println("Tour capacity exceeded");

	        return;

	    }

	    // creating city tour object
	    CityTour newBooking =
	            new CityTour(
	                    tourName,
	                    adultPrice,
	                    childPrice,
	                    duration,
	                    adultCount,
	                    childCount,
	                    currentUser.getName()
	            );

	    bookings.add(newBooking);

	    System.out.println("Booking Added Successfully");

	}

	public static void searchBooking(ArrayList<Tour>bookings, int searchTicket) {
		boolean found = false;
		for(Tour t: bookings) {
			if(t.getTicketNumber()==searchTicket) {
				t.displayTour();
				found = true;
			}
		}
		if(!found) {
			System.out.println("Ticket not found");
		}
	}
	
