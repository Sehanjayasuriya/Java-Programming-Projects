	//add queensland tour
	public static void addQueenslandTour(
	        ArrayList<Tour> bookings,
	        Scanner input,
	        User currentUser
	) {

	    System.out.println("===== Queensland Tours =====");

	    System.out.println("1. Cairns");
	    System.out.println("2. Gold Coast");

	    System.out.print("Choose Tour: ");

	    int choice = input.nextInt();

	    String tourName = "";
	    double adultPrice = 0;
	    double childPrice = 0;

	    switch(choice) {

	        case 1:
	            tourName = "Cairns";
	            adultPrice = 850;
	            childPrice = 700;
	            break;

	        case 2:
	            tourName = "Gold Coast";
	            adultPrice = 600;
	            childPrice = 450;
	            break;

	        default:
	            System.out.println("Invalid Tour");
	            return;

	    }

	    System.out.print("Enter Adult Count: ");
	    int adultCount = input.nextInt();

	    System.out.print("Enter Child Count: ");
	    int childCount = input.nextInt();

	    //maximum capacity
	    if(adultCount + childCount > 40) {

	        System.out.println("Tour capacity exceeded");
	        return;

	    }

	    input.nextLine();

	    System.out.print("Enter Boarding Airport: ");
	    String boardingAirport = input.nextLine();

	    int totalPeople = adultCount + childCount;

	    double pickupCost;

	    // calculating pickup cost
	    if(totalPeople <= 6) {

	        pickupCost = 150;

	        System.out.println(
	                "Pickup Cost Automatically Added: 150"
	        );

	    }

	    else {

	        System.out.print("Enter Pickup Cost: ");

	        pickupCost = input.nextDouble();

	        input.nextLine();

	    }

	    System.out.print("Enter Customer Name: ");

	    String customerName = input.nextLine();

	    System.out.print("Enter Contact Number: ");

	    String contactNumber = input.nextLine();

	    String insuranceType = "No Insurance";

	    double insurancePrice = 0;

	    System.out.print("Do you want insurance? (Y/N): ");

	    String answer = input.nextLine();

	    // optional insurance selection
	    if(answer.equalsIgnoreCase("Y")) {

	        System.out.println("1. Single - 200");
	        System.out.println("2. Couple - 350");
	        System.out.println("3. Family - 500");

	        System.out.print("Choose Insurance Type: ");

	        int insuranceChoice = input.nextInt();

	        input.nextLine();

	        switch(insuranceChoice) {

	            case 1:
	                insuranceType = "Single";
	                insurancePrice = 200;
	                break;

	            case 2:
	                insuranceType = "Couple";
	                insurancePrice = 350;
	                break;

	            case 3:
	                insuranceType = "Family";
	                insurancePrice = 500;
	                break;

	            default:
	                System.out.println("Invalid Insurance");
	                return;

	        }

	    }

	    Customer customer =
	            new Customer(customerName, contactNumber);

	    QueenslandTour newBooking =
	            new QueenslandTour(
	                    tourName,
	                    adultPrice,
	                    childPrice,
	                    adultCount,
	                    childCount,
	                    boardingAirport,
	                    pickupCost,
	                    insuranceType,
	                    insurancePrice,
	                    customer,
	                    currentUser.getName()
	            );

	    bookings.add(newBooking);

	    System.out.println("Booking Added Successfully");

	}
	
	//add international tour. Insurance is mandatory
	public static void addInternationalTour(
	        ArrayList<Tour> bookings,
	        Scanner input,
	        User currentUser
	) {

	    try {

	        System.out.println(
	                "===== International Tours ====="
	        );

	        System.out.println("1. Phuket");
	        System.out.println("2. Pattaya");
	        System.out.println("3. Singapore");

	        System.out.print("Choose Tour: ");

	        int choice = input.nextInt();

	        // variables for selected tour
	        String tourName = "";
	        double adultPrice = 0;
	        double childPrice = 0;

	        // selecting international tour
	        switch(choice) {

	            case 1:
	                tourName = "Phuket";
	                adultPrice = 1350;
	                childPrice = 1100;
	                break;

	            case 2:
	                tourName = "Pattaya";
	                adultPrice = 1400;
	                childPrice = 1150;
	                break;

	            case 3:
	                tourName = "Singapore";
	                adultPrice = 1200;
	                childPrice = 1000;
	                break;

	            default:
	                System.out.println("Invalid Tour");
	                return;

	        }

	        System.out.print("Enter Adult Count: ");

	        int adultCount = input.nextInt();

	        System.out.print("Enter Child Count: ");

	        int childCount = input.nextInt();

	        // capacity validation
	        if(adultCount + childCount > 40) {

	            System.out.println("Tour capacity exceeded");
	            return;

	        }

	        input.nextLine();

	        System.out.print("Enter Boarding Airport: ");

	        String boardingAirport = input.nextLine();

	        // pickup cost calculation
	        int totalPeople = adultCount + childCount;

	        double pickupCost;

	        if(totalPeople <= 6) {

	            pickupCost = 150;

	            System.out.println(
	                    "Pickup Cost Automatically Added: 150"
	            );

	        }

	        else {

	            System.out.print("Enter Pickup Cost: ");

	            pickupCost = input.nextDouble();

	            input.nextLine();

	        }

	        // insurance menu
	        System.out.println("1. Single - 200");
	        System.out.println("2. Couple - 350");
	        System.out.println("3. Family - 500");

	        System.out.print("Choose Insurance Type: ");

	        int insuranceChoice = input.nextInt();

	        input.nextLine();

	        String insuranceType = "";

	        double insurancePrice = 0;

	        switch(insuranceChoice) {

	            case 1:
	                insuranceType = "Single";
	                insurancePrice = 200;
	                break;

	            case 2:
	                insuranceType = "Couple";
	                insurancePrice = 350;
	                break;

	            case 3:
	                insuranceType = "Family";
	                insurancePrice = 500;
	                break;

	            default:
	            	// custom exception
	                throw new NoInsuranceException(
	                        "International Tour requires insurance"
	                );

	        }

	        // customer details
	        System.out.print("Enter Customer Name: ");

	        String customerName = input.nextLine();

	        System.out.print("Enter Contact Number: ");

	        String contactNumber = input.nextLine();

	        Customer customer =
	                new Customer(customerName, contactNumber);

	        // international booking object
	        InternationalTour newBooking =
	                new InternationalTour(
	                        tourName,
	                        adultPrice,
	                        childPrice,
	                        adultCount,
	                        childCount,
	                        boardingAirport,
	                        pickupCost,
	                        insuranceType,
	                        insurancePrice,
	                        currentUser.getName(),
	                        customer
	                );

	        bookings.add(newBooking);

	        System.out.println(
	                "Booking Added Successfully"
	        );

	    }

	    // exception handling
	    catch(NoInsuranceException e) {

	        System.out.println(e.getMessage());

	    }

	}
	
	
	//Cancels booking using ticket number,  Refunds 75% of total amount
	public static void cancelBooking(
	        ArrayList<Tour> bookings,
	        int searchTicket
	) {

	    boolean found = false;

	    // searching booking
	    for(Tour t : bookings) {

	        if(t.getTicketNumber() == searchTicket) {

	        	// check already cancelled
	            if(t.isCancelled()) {

	                System.out.println(
	                        "Ticket already cancelled"
	                );

	                return;

	            }

	            // refund calculation
	            double refund =
	                    t.calculatePrice() * 0.75;

	            System.out.println(
	                    "Refund: " + refund
	            );

	            // mark as cancelled
	            t.setCancelled(true);

	            System.out.println(
	                    "Ticket Cancelled"
	            );

	            found = true;

	        }

	    }

	    if(!found) {

	        System.out.println("Ticket not found");

	    }

	}
	
	
	//Displays all bookings
    public static void printBookings(ArrayList<Tour> bookings) {

    	// displaying all bookings
        for(Tour t : bookings) {

            t.displayTour();
            System.out.println();

        }

    }
    
    //Prints bookings for a specific tour
    public static void printSpecificTour(
            ArrayList<Tour> bookings,
            Scanner input
    ) {

        input.nextLine();

        System.out.print("Enter Tour Name: ");

        String searchTour =
                input.nextLine();

        boolean found = false;

        // searching bookings by tour name
        for(Tour t : bookings) {

            if(t.getTourName().equalsIgnoreCase(searchTour)) {
                t.displayTour();
                System.out.println();
                found = true;

            }

        }

        if(!found) {

            System.out.println("Tour not found");

        }

    }

    
    //Main method starting point of the program
    public static void main(String[] args) {

    	//ArrayList to store bookings
        ArrayList<Tour> bookings = new ArrayList<>();
        
        // ArrayList to store users
        ArrayList<User> users = new ArrayList<>();

        // loading users from file
        loadUsers(users);

        // create default admin if no users exist
        if(users.isEmpty()) {

            Admin admin = new Admin(
                    "Admin",
                    "admin",
                    "admin123"
            );

            users.add(admin);
            saveUsers(users);

        }
        
        Scanner input = new Scanner(System.in);
        
        //current logged in user
        User currentUser = null;
        
        //login validation loop
        while(currentUser == null) {

            currentUser = login(users, input);

        }
        
        //admin access only to admin menu
        if(currentUser instanceof Admin) {

            adminMenu(users, input);
            input.close();
            return;

        }
        
        int choice;

        // main system menu
        do {

            System.out.println("\nTravel Australia");
            System.out.println("1. Add City Tour");
            System.out.println("2. Add Attractions Tour");
            System.out.println("3. Add Queensland Tour");
            System.out.println("4. Add International Tour");
            System.out.println("5. Print Bookings");
            System.out.println("6. Print Specific Tour ");
            System.out.println("7. Search Ticket");
            System.out.println("8. Cancel Ticket");
            System.out.println("9. Sales Report");
            System.out.println("10. Exit");

            System.out.print("Enter Option: ");

            choice = input.nextInt();

            switch(choice) {
            
            	case 1:
            		addCityTour(bookings,input,currentUser);
            		break;
            		
            	case 2:
            	    addAttractionsTour(bookings, input, currentUser);
            	    break;
            	
            	case 3:
            		addQueenslandTour(bookings,input,currentUser);
            		break;
            		
            	case 4:
            		addInternationalTour(bookings,input,currentUser);
            		break;

                case 5:
                    printBookings(bookings);
                    break;
                    
                case 6:
                    printSpecificTour(bookings, input);
                    break;
                    
                case 7:
                	System.out.println("Enter Ticket Number: ");
                	int searchTicket = input.nextInt();
                	
                	searchBooking(bookings, searchTicket);
                	break;
                	
                case 8:
                	System.out.println("Enter Ticket Number: ");
                	int cancelTicket=input.nextInt();
                	
                	cancelBooking(bookings, cancelTicket);
                	break;
                	
                case 9:
                	salesReport(bookings);
                	break;

                case 10:

                    System.out.println("Exiting...");
                    break;

                default:

                    System.out.println("Invalid Option");

            }

        }while(choice != 10);

        input.close();
    }

}
